From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Telesphoreo <me@telesphoreo.me>
Date: Sat, 18 Jul 2026 18:29:16 -0400
Subject: [PATCH] Reject invalid nested item components

Cover malformed item templates in bundle contents so strict validation cannot regress and expose client crashes.

diff --git a/src/test/java/io/papermc/paper/item/ItemStackValidationTest.java b/src/test/java/io/papermc/paper/item/ItemStackValidationTest.java
new file mode 100644
index 0000000000000000000000000000000000000000..5577fd1e15d198b4afd08043715bba2e843fdf55
--- /dev/null
+++ b/src/test/java/io/papermc/paper/item/ItemStackValidationTest.java
@@ -0,0 +1,70 @@
+package io.papermc.paper.item;
+
+import java.util.List;
+import net.minecraft.core.component.DataComponentPatch;
+import net.minecraft.core.component.DataComponents;
+import net.minecraft.nbt.NbtOps;
+import net.minecraft.nbt.Tag;
+import net.minecraft.resources.RegistryOps;
+import net.minecraft.world.item.ItemStack;
+import net.minecraft.world.item.ItemStackTemplate;
+import net.minecraft.world.item.Items;
+import net.minecraft.world.item.component.BundleContents;
+import org.bukkit.support.RegistryHelper;
+import org.bukkit.support.environment.AllFeatures;
+import org.junit.jupiter.api.Test;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.junit.jupiter.api.Assertions.assertSame;
+import static org.junit.jupiter.api.Assertions.assertTrue;
+
+@AllFeatures
+class ItemStackValidationTest {
+
+    private static final ItemStackTemplate INVALID_HOE = new ItemStackTemplate(
+        Items.NETHERITE_HOE,
+        DataComponentPatch.builder().set(DataComponents.MAX_STACK_SIZE, 69).build()
+    );
+    private static final ItemStackTemplate VALID_DIAMOND = new ItemStackTemplate(Items.DIAMOND, 3);
+
+    @Test
+    void rejectsInvalidItemInBundle() {
+        final ItemStack bundle = new ItemStack(Items.BUNDLE);
+        bundle.set(DataComponents.BUNDLE_CONTENTS, new BundleContents(List.of(INVALID_HOE)));
+        bundle.set(DataComponents.MAX_STACK_SIZE, 99);
+
+        assertTrue(ItemStack.validateStrict(bundle).isError());
+    }
+
+    @Test
+    void sanitizeBundleContentsRemovesInvalidEntries() {
+        final ItemStack bundle = new ItemStack(Items.BUNDLE);
+        bundle.set(DataComponents.BUNDLE_CONTENTS, new BundleContents(List.of(INVALID_HOE, VALID_DIAMOND)));
+
+        final ItemStack sanitized = ItemStack.sanitizeBundleContents(bundle);
+
+        assertEquals(List.of(VALID_DIAMOND), sanitized.get(DataComponents.BUNDLE_CONTENTS).items());
+        assertEquals(2, bundle.get(DataComponents.BUNDLE_CONTENTS).items().size());
+    }
+
+    @Test
+    void sanitizeBundleContentsKeepsValidBundles() {
+        final ItemStack bundle = new ItemStack(Items.BUNDLE);
+        bundle.set(DataComponents.BUNDLE_CONTENTS, new BundleContents(List.of(VALID_DIAMOND)));
+
+        assertSame(bundle, ItemStack.sanitizeBundleContents(bundle));
+    }
+
+    @Test
+    void deserializationRemovesInvalidBundleEntries() {
+        final ItemStack bundle = new ItemStack(Items.BUNDLE);
+        bundle.set(DataComponents.BUNDLE_CONTENTS, new BundleContents(List.of(INVALID_HOE, VALID_DIAMOND)));
+
+        final RegistryOps<Tag> ops = RegistryHelper.registryAccess().createSerializationContext(NbtOps.INSTANCE);
+        final Tag encoded = ItemStack.CODEC.encodeStart(ops, bundle).getOrThrow();
+        final ItemStack loaded = ItemStack.CODEC.parse(ops, encoded).getOrThrow();
+
+        assertEquals(List.of(VALID_DIAMOND), loaded.get(DataComponents.BUNDLE_CONTENTS).items());
+    }
+
+}
