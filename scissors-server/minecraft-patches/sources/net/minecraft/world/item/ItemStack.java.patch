+    // Returns a rebuilt container with invalid slots cleared, or null when every occupied slot is already valid.
+    private static @Nullable ItemContainerContents filterValidContainer(final ItemContainerContents container) {
+        List<Optional<ItemStackTemplate>> slots = container.items;
+        List<ItemStack> rebuilt = null;
+        for (int i = 0; i < slots.size(); i++) {
+            Optional<ItemStackTemplate> slot = slots.get(i);
+            boolean ok = slot.isEmpty() || isValidNestedItem(slot.get());
+            if (!ok && rebuilt == null) {
+                rebuilt = new java.util.ArrayList<>();
