+    // Returns a filtered copy with invalid entries dropped, or null when every entry is already valid.
+    private static @Nullable List<ItemStackTemplate> filterValidNestedItems(final List<ItemStackTemplate> items) {
+        List<ItemStackTemplate> valid = null;
+        for (int i = 0; i < items.size(); i++) {
+            ItemStackTemplate item = items.get(i);
+            boolean ok = isValidNestedItem(item);
+            if (!ok && valid == null) {
+                valid = new java.util.ArrayList<>(items.subList(0, i));
+            } else if (ok && valid != null) {
+                valid.add(item);
+            }
+        }
+        return valid;
+    }
